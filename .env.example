# Public API endpoint used by browser requests (must include /api/v1)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Optional server-side API endpoint for SSR/server actions
API_BASE_URL=http://localhost:8000/api/v1

# OIDC login UI toggle (only enable if backend provider is configured)
NEXT_PUBLIC_OIDC_ENABLED=false
NEXT_PUBLIC_OIDC_PROVIDER=OIDC
